<Component name="Transcript"
  var.fullscreenImage="{null}"
  var.openToolId="{null}"
  var.turnLimit="{50}"
  var.showAll="{false}"
  var.pendingMenu="{null}"
  var.currentTurnEditsTick="{0}"
  var.currentTurnEditsTickAt="{0}"
  var.turns="{sessionTurnsDS.value || []}">
  <!-- Host-derived current-turn edits (replaces iframe-side
       currentTurnEdits(lastJsonl) walk). Refetch driven by a tick
       bumped from the iframe's subscribeLatestJsonl callback, 2 s
       throttled. Same tick drives all three Transcript DataSources. -->
  <DataSource
    id="currentTurnEditsDS"
    url="/__current-turn-edits?t={currentTurnEditsTick}" />
  <!-- Host-derived "agent is waiting for assistant" boolean. Replaces
       the iframe isWaitingForAssistant suffix-walk that fired
       on every keystroke (TextArea `enabled` binding) AND every JSONL
       fanout. -->
  <DataSource
    id="waitingDS"
    url="/__waiting-for-assistant?t={currentTurnEditsTick}" />
  <!-- Host-derived turn timeline. Replaces the iframe sessionTurns
       (~95 LOC) + _parseLinesToTurns (~106 LOC) chain that walked
       the full session JSONL on every fanout. -->
  <DataSource
    id="sessionTurnsDS"
    url="/__session-turns?t={currentTurnEditsTick}" />
  <!-- Host-derived full input + result for one tool, keyed on the
       currently-open tool's id. Replaces getToolDetail iframe walk. -->
  <DataSource
    id="toolDetailDS"
    url="/__tool-detail?id={openToolId || ''}"
    when="{!!openToolId}" />
  <ChangeListener
    listenTo="{turns.length}"
    onDidChange="if (window.wasPinnedToBottom()) window.scrollAllToBottom()" />


  <ModalDialog
    when="{!!fullscreenImage}"
    fullScreen="true"
    onClose="fullscreenImage = null">
    <Image
      src="{(fullscreenImage || '').startsWith('data:') || (fullscreenImage || '').startsWith('http') ? fullscreenImage : '/__file?path=' + encodeURIComponent(fullscreenImage || '')}"
      fit="contain"
      width="100%"
      height="100%" />
  </ModalDialog>

  <ModalDialog
    when="{!!openToolId}"
    onClose="openToolId = null"
    title="{(findToolInTurns(turns, openToolId) || {}).name || 'Tool'}"
    var.openTool="{findToolInTurns(turns, openToolId)}"
    var.openDetail="{toolDetailDS.value}"
    var.modalInput="{openDetail &amp;&amp; openDetail.input}"
    var.modalResult="{openDetail &amp;&amp; openDetail.result}">
    <VStack gap="$space-2">
      <Text
        when="{openTool &amp;&amp; openTool.summary}"
        fontFamily="$fontFamily-monospace"
        fontSize="$fontSize-sm"
        color="$textColor-secondary"
        value="{openTool.summary}" />
      <Items
        when="{openTool &amp;&amp; (openTool.name === 'Edit' || openTool.name === 'MultiEdit')}"
        data="{editDiffLines(modalInput)}">
        <Text
          fontFamily="$fontFamily-monospace"
          fontSize="$fontSize-sm"
          whiteSpace="pre-wrap"
          paddingHorizontal="$space-2"
          backgroundColor="{$item.kind === 'del' ? '$color-danger-100' : '$color-success-100'}"
          value="{$item.sign + ' ' + $item.text}" />
      </Items>
      <VStack when="{openTool &amp;&amp; openTool.name === 'Write'}" gap="{0}" var.writeBody="{writeBodyLines(modalInput, 200)}">
        <Items data="{writeBody.lines}">
          <Text
            fontFamily="$fontFamily-monospace"
            fontSize="$fontSize-sm"
            whiteSpace="pre-wrap"
            paddingHorizontal="$space-2"
            value="{$item}" />
        </Items>
        <Text
          when="{writeBody.remaining > 0}"
          fontSize="$fontSize-xs"
          color="$textColor-secondary"
          paddingHorizontal="$space-2"
          value="{writeBody.remaining + ' more line' + (writeBody.remaining === 1 ? '' : 's') + '…'}" />
      </VStack>
      <VStack when="{openTool &amp;&amp; openTool.name === 'Bash'}" gap="$space-1">
        <Text
          fontFamily="$fontFamily-monospace"
          fontSize="$fontSize-sm"
          whiteSpace="pre-wrap"
          paddingHorizontal="$space-2"
          value="{modalInput.command}" />
        <Text
          when="{modalInput.description}"
          fontSize="$fontSize-xs"
          color="$textColor-secondary"
          paddingHorizontal="$space-2"
          value="{modalInput.description}" />
      </VStack>
      <VStack
        when="{openTool &amp;&amp; openTool.name !== 'Edit' &amp;&amp; openTool.name !== 'MultiEdit' &amp;&amp; openTool.name !== 'Write' &amp;&amp; openTool.name !== 'Bash'}"
        gap="{0}"
        var.genericBody="{toolInputJsonLines(modalInput, 200)}">
        <Items data="{genericBody.lines}">
          <Text
            fontFamily="$fontFamily-monospace"
            fontSize="$fontSize-sm"
            whiteSpace="pre-wrap"
            paddingHorizontal="$space-2"
            value="{$item}" />
        </Items>
        <Text
          when="{genericBody.remaining > 0}"
          fontSize="$fontSize-xs"
          color="$textColor-secondary"
          paddingHorizontal="$space-2"
          value="{genericBody.remaining + ' more line' + (genericBody.remaining === 1 ? '' : 's') + '…'}" />
      </VStack>
      <VStack when="{modalResult &amp;&amp; modalResult.lines.length > 0}" gap="{0}" marginTop="$space-2">
        <Text
          fontSize="$fontSize-xs"
          fontWeight="$fontWeight-bold"
          color="$textColor-secondary"
          paddingHorizontal="$space-2"
          value="Result" />
        <Items data="{modalResult.lines}">
          <Text
            fontFamily="$fontFamily-monospace"
            fontSize="$fontSize-sm"
            whiteSpace="pre-wrap"
            paddingHorizontal="$space-2"
            color="{openTool &amp;&amp; openTool.errored ? '$color-danger-700' : ''}"
            value="{$item}" />
        </Items>
        <Text
          when="{modalResult.remaining > 0}"
          fontSize="$fontSize-xs"
          color="$textColor-secondary"
          paddingHorizontal="$space-2"
          value="{modalResult.remaining + ' more line' + (modalResult.remaining === 1 ? '' : 's') + '…'}" />
      </VStack>
    </VStack>
  </ModalDialog>

  <VStack padding="$space-6" gap="$space-3"
    onInit="subscribeLatestJsonl('__bramTranscriptJsonlUnsub', () => { const now = Date.now(); if (now - currentTurnEditsTickAt >= 2000) { currentTurnEditsTickAt = now; currentTurnEditsTick = currentTurnEditsTick + 1; } }); (() => { const tauri = (window.parent &amp;&amp; window.parent.__TAURI__) || window.__TAURI__; if (tauri &amp;&amp; tauri.event &amp;&amp; tauri.event.listen) { if (typeof window.__bramTranscriptPtyMenuUnlisten === 'function') { try { window.__bramTranscriptPtyMenuUnlisten(); } catch (err) {} window.__bramTranscriptPtyMenuUnlisten = null; } tauri.event.listen('pty-menu-changed', (e) => { pendingMenu = e &amp;&amp; e.payload ? e.payload : null; }).then((unlisten) => { window.__bramTranscriptPtyMenuUnlisten = unlisten; }).catch(() => {}); } })(); try { logToHost({ kind: 'transcript-mount', at: new Date().toISOString() }) } catch (e) {}">
    <StickyBox to="top">
      <HStack gap="$space-3" verticalAlignment="center" paddingVertical="$space-2">
        <Heading level="h2">Transcript</Heading>
        <SpaceFiller />
        <Button
          icon="down"
          variant="ghost"
          size="xs"
          tooltip="Scroll to bottom"
          onClick="window.scrollAllToBottom()" />
      </HStack>
    </StickyBox>

    <Link
      when="{!showAll || turns.length > turnLimit}"
      onClick="if (!showAll) { showAll = true; window.fetch('/__sessions/latest-tail?provider=' + encodeURIComponent(activeProvider || '') + '&amp;lines=all').then((r) => r.json()).then((env) => { if (env &amp;&amp; env.content !== undefined) { window.setLatestJsonl(env.content); } }); } else { turnLimit = turns.length; }"
      noIndicator="true">
      <Text fontSize="$fontSize-sm" color="$textColor-secondary"
        value="{showAll ? ('Show all (' + (turns.length - turnLimit) + ' earlier)') : 'Show earlier turns'}" />
    </Link>

    <Items data="{visibleTurns(turns, turnLimit)}">
      <VStack
        gap="$space-1"
        padding="$space-3"
        borderRadius="$borderRadius"
        backgroundColor="{$item.role === 'user' ? '$color-info-50' : '$color-surface-50'}"
        var.turnRole="{$item.role}"
        var.turnImages="{$item.images}">
        <Text
          fontSize="$fontSize-sm"
          fontWeight="$fontWeight-bold"
          color="{turnRole === 'user' ? '$color-info-700' : '$color-success-700'}"
          value="{turnRole === 'user' ? 'You' : 'Agent'}" />
        <Items data="{$item.entries}">
          <Markdown
            when="{$item.kind === 'text'}"
            content="{turnRole === 'user' ? formatUserTurnForTranscript($item.text) : $item.text}" />
          <VStack
            when="{$item.kind === 'tool'}"
            gap="$space-1"
            padding="$space-2"
            borderRadius="$borderRadius"
            border="1px solid $borderColor"
            backgroundColor="$color-surface-100"
            var.toolId="{$item.id}"
            var.toolName="{$item.name}"
            var.toolErrored="{$item.errored}"
            var.toolErrorText="{$item.errorText}"
            var.toolSummaryText="{$item.summary}">
            <Link onClick="openToolId = toolId" noIndicator="true">
              <HStack gap="$space-2" verticalAlignment="center">
                <Text
                  fontFamily="$fontFamily-monospace"
                  fontSize="$fontSize-xs"
                  fontWeight="$fontWeight-bold"
                  paddingHorizontal="$space-1_5"
                  paddingVertical="$space-0_5"
                  borderRadius="$borderRadius"
                  backgroundColor="$color-surface-200"
                  value="{toolName}" />
                <Text fontSize="$fontSize-sm" value="{toolSummaryText}" />
                <SpaceFiller />
                <Text fontFamily="$fontFamily-monospace" fontSize="$fontSize-xs" color="$textColor-secondary" value="↗" />
              </HStack>
            </Link>
            <Text
              when="{toolErrored &amp;&amp; toolErrorText}"
              color="$color-danger-700"
              fontSize="$fontSize-sm"
              value="{toolErrorText}" />
          </VStack>
        </Items>
        <VStack gap="$space-2" when="{turnImages &amp;&amp; turnImages.length > 0}">
          <Items data="{turnImages}">
            <Link onClick="fullscreenImage = $item" noIndicator>
              <Image
                src="{$item.startsWith('data:') || $item.startsWith('http') ? $item : '/__file?path=' + encodeURIComponent($item)}"
                maxHeight="200px"
                fit="contain" />
            </Link>
          </Items>
        </VStack>
      </VStack>
    </Items>

    <VStack
      when="{pendingMenu}"
      gap="$space-2"
      padding="$space-3"
      borderRadius="$borderRadius"
      border="1px solid $color-warn-200"
      backgroundColor="$color-warn-50">
      <Text fontSize="$fontSize-sm" color="$color-warn-800">
        Agent wants to use <Text fontFamily="$fontFamily-monospace" inline="true">{pendingMenu.tool}</Text>
      </Text>
      <HStack gap="$space-2" wrapContent="true">
        <Button label="1. Yes" variant="outlined" size="sm" onClick="sendKeys('1\r')" />
        <Button label="2. Yes, allow and don't ask again" variant="outlined" size="sm" onClick="sendKeys('2\r')" />
        <Button label="3. No, and tell agent what to do" variant="outlined" size="sm" onClick="sendKeys('3\r')" />
      </HStack>
    </VStack>

    <HStack
      when="{(waitingDS.value &amp;&amp; waitingDS.value.waiting) &amp;&amp; !pendingMenu}"
      paddingVertical="$space-3"
      verticalAlignment="center">
      <Spinner size="sm" delay="{200}" />
    </HStack>

    <StickyBox to="bottom">
      <VStack gap="{0}"
        backgroundColor="$color-surface-50"
        borderTop="1px solid $borderColor"
        var.turnEdits="{currentTurnEditsDS.value || []}">
        <VStack
          when="{turnEdits.length > 0}"
          gap="{0}"
          paddingHorizontal="$space-2"
          paddingVertical="$space-1"
          borderBottom="1px solid $borderColor">
          <Items data="{turnEdits}">
            <Link
              when="{$item.lastToolId}"
              onClick="openToolId = $item.lastToolId"
              noIndicator="true">
              <HStack gap="$space-2" verticalAlignment="center">
                <Text
                  fontFamily="$fontFamily-monospace"
                  fontSize="$fontSize-xs"
                  color="$textColor-secondary"
                  value="{$item.filePath}" />
                <SpaceFiller />
                <Text
                  fontFamily="$fontFamily-monospace"
                  fontSize="$fontSize-xs"
                  color="$color-success-700"
                  value="+{$item.added}" />
                <Text
                  fontFamily="$fontFamily-monospace"
                  fontSize="$fontSize-xs"
                  color="$color-danger-700"
                  value="-{$item.removed}" />
              </HStack>
            </Link>
            <HStack
              when="{!$item.lastToolId}"
              gap="$space-2"
              verticalAlignment="center">
              <Text
                fontFamily="$fontFamily-monospace"
                fontSize="$fontSize-xs"
                color="$textColor-secondary"
                value="{$item.filePath}" />
              <SpaceFiller />
              <Text
                fontFamily="$fontFamily-monospace"
                fontSize="$fontSize-xs"
                color="$color-success-700"
                value="+{$item.added}" />
              <Text
                fontFamily="$fontFamily-monospace"
                fontSize="$fontSize-xs"
                color="$color-danger-700"
                value="-{$item.removed}" />
            </HStack>
          </Items>
        </VStack>
        <HStack gap="$space-2" padding="$space-2" verticalAlignment="end">
          <Button icon="up" variant="ghost" size="xs"
            tooltip="Scroll to top" onClick="window.scrollAllToTop()" />
          <Form width="*"
            onSubmit="if (inputBox.value &amp;&amp; inputBox.value.trim()) { toTurn(inputBox.value); inputBox.setValue('') }">
            <property name="buttonRowTemplate"><Fragment/></property>
            <HStack gap="$space-2" verticalAlignment="end">
              <TextArea id="inputBox" enterSubmits="true"
                enabled="{!(waitingDS.value &amp;&amp; waitingDS.value.waiting)}"
                placeholder="Message agent — Enter sends, Shift+Enter newline"
                autoSize="true" minRows="1" maxRows="6" width="*" />
              <Button label="Send" type="submit" size="sm" />
            </HStack>
          </Form>
        </HStack>
      </VStack>
    </StickyBox>
  </VStack>
</Component>
