<Component
  name="Status"
  var.refreshTick="{0}"
  var.sectionInfoTitle="{''}"
  var.sectionInfoDescription="{''}">

  <DataSource id="status" url="/__coordination-status?t={refreshTick}" />

  <VStack padding="$space-6" gap="$space-4">
    <HStack gap="$space-3" verticalAlignment="center">
      <Heading level="h2">Status</Heading>
      <SpaceFiller />
      <Text
        when="{status.value}"
        fontSize="$fontSize-sm"
        color="$textColor-secondary"
        value="{'Updated ' + ((status.value.generatedAt || '').slice(11, 19))}" />
      <Button
        label="Refresh"
        size="sm"
        onClick="refreshTick = refreshTick + 1; status.refetch();" />
    </HStack>

    <Text
      when="{status.inProgress}"
      color="$textColor-secondary"
      fontSize="$fontSize-sm"
      value="Loading coordination signals..." />

    <Text
      when="{status.error}"
      color="$color-danger-700"
      fontSize="$fontSize-sm"
      value="Status signals failed to load." />

    <Text
      when="{!status.inProgress &amp;&amp; !status.error &amp;&amp; !(status.value &amp;&amp; status.value.sections &amp;&amp; status.value.sections.length)}"
      color="$textColor-secondary"
      fontSize="$fontSize-sm"
      value="No coordination signals found." />

    <Items data="{status.value &amp;&amp; status.value.sections || []}">
      <VStack gap="$space-2">
        <HStack gap="$space-2" verticalAlignment="baseline">
          <Heading level="h3" value="{$item.title}" />
          <Text
            when="{statusSectionSubhead($item.title)}"
            fontSize="$fontSize-sm"
            color="$textColor-secondary"
            value="{'— ' + statusSectionSubhead($item.title)}" />
          <Button
            when="{statusSectionDescription($item.title)}"
            icon="info"
            size="xs"
            variant="ghost"
            tooltip="About this section"
            onClick="sectionInfoTitle = $item.title; sectionInfoDescription = statusSectionDescription($item.title); sectionInfoDialog.open()" />
        </HStack>
        <Table data="{$item.rows}">
          <Column header="signal" bindTo="signal" width="170px" />
          <Column header="level" width="80px">
            <Text
              fontWeight="$fontWeight-bold"
              color="{$item.level === 'warn' ? '$color-warn-700' : ($item.level === 'ok' ? '$color-success-700' : '$textColor-secondary')}"
              value="{$item.level || 'n/a'}" />
          </Column>
          <Column header="state" width="150px">
            <Text
              fontWeight="$fontWeight-bold"
              value="{$item.state}" />
          </Column>
          <Column header="detail">
            <Text value="{$item.detail}" overflowMode="flow" breakMode="word" />
          </Column>
          <Column header="last seen" width="175px">
            <Text
              fontSize="$fontSize-sm"
              color="$textColor-secondary"
              value="{$item.seen || 'n/a'}" />
          </Column>
        </Table>
      </VStack>
    </Items>

    <ModalDialog
      id="sectionInfoDialog"
      title="{sectionInfoTitle}">
      <VStack gap="$space-3" padding="$space-2">
        <Text value="{sectionInfoDescription}" />
        <HStack>
          <Button label="Got it" onClick="sectionInfoDialog.close()" />
        </HStack>
      </VStack>
    </ModalDialog>
  </VStack>
</Component>
