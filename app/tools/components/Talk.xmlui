<Component name="Talk" var.turns="{sessionTurns(latestSession.value)}" var.escSuppressed="{false}">
  <DataSource
    id="latestSession"
    url="/__sessions/latest"
    pollIntervalInSeconds="2" />

  <ChangeListener
    listenTo="{turns.length}"
    onDidChange="if (window.wasPinnedToBottom()) window.scrollAllToBottom()" />

  <ChangeListener
    listenTo="{turns.filter(t => t.role === 'user' && !t.text.startsWith('[Request interrupted')).length}"
    onDidChange="escSuppressed = false" />

  <VStack padding="$space-6" gap="$space-3">
    <StickyBox to="top">
      <HStack gap="$space-3" verticalAlignment="center" paddingVertical="$space-2">
        <Heading level="h2">Transcript</Heading>
        <SpaceFiller />
        <Button
          icon="down"
          variant="ghost"
          size="xs"
          tooltip="Scroll to bottom"
          onClick="window.scrollAllToBottom()" />
      </HStack>
    </StickyBox>

    <Text
      when="{!turns || turns.length === 0}"
      color="$textColor-secondary">
      (no messages yet)
    </Text>

    <Items data="{turns}">
      <VStack
        gap="$space-1"
        padding="$space-3"
        borderRadius="$borderRadius"
        backgroundColor="{$item.role === 'user' ? '$color-info-50' : '$color-surface-50'}">
        <Text
          fontSize="$fontSize-sm"
          fontWeight="$fontWeight-bold"
          color="{$item.role === 'user' ? '$color-info-700' : '$color-success-700'}"
          value="{$item.role === 'user' ? 'You' : 'Claude'}" />
        <Markdown
          content="{$item.role === 'user' ? formatUserTurnForTranscript($item.text) : $item.text}" />
      </VStack>
    </Items>

    <HStack
      when="{isWaitingForAssistant(latestSession.value) && !escSuppressed}"
      paddingVertical="$space-3"
      gap="$space-3"
      verticalAlignment="center">
      <Spinner size="sm" delay="{200}" />
      <Button
        label="Esc"
        variant="ghost"
        size="xs"
        tooltip="Send Esc to interrupt"
        onClick="(sendKeys('\x1b'), escSuppressed = true)" />
    </HStack>

    <StickyBox to="bottom">
      <HStack horizontalAlignment="end" gap="$space-2" paddingVertical="$space-2">
        <Button
          label="Yes"
          variant="ghost"
          size="xs"
          tooltip="Permission menu: choose 1 (Yes)"
          onClick="sendKeys('1\r')" />
        <Button
          label="No"
          variant="ghost"
          size="xs"
          tooltip="Permission menu: choose 2 (No)"
          onClick="sendKeys('2\r')" />
        <Button
          icon="up"
          variant="ghost"
          size="xs"
          tooltip="Scroll to top"
          onClick="window.scrollAllToTop()" />
      </HStack>
    </StickyBox>
  </VStack>
</Component>
