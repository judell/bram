{
  "permissions": {
    "allow": [
      "Write(./resources/worklist.json)",
      "Edit(./resources/worklist.json)",
      "Bash(curl -s \"http://localhost*__worklist*)",
      "Bash(curl -s -X POST -d * \"http://localhost*__worklist*)",
      "Bash(curl -s \"http://127.0.0.1*__worklist*)",
      "Bash(curl -s -X POST -d * \"http://127.0.0.1*__worklist*)",
      "Bash(curl -s \"http://localhost*__issues*)",
      "Bash(curl -s -X POST -d * \"http://localhost*__iterate*)",
      "Bash(curl -s \"http://localhost*__enhance*)",
      "mcp__xmlui"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/worklist-guard.py"
          }
        ]
      }
    ]
  }
}
