echo "You can launch claude or codex here."
# To auto-launch one on shell start, add to .xmlui-desktop.json:
#   { "shell": { "agent": "claude --continue" } }

_XMLUI_SHELL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

_xmlui_mark_agent() {
  [ -n "$XMLUI_DESKTOP_AGENT_HINT" ] || return 0
  mkdir -p "$(dirname "$XMLUI_DESKTOP_AGENT_HINT")" 2>/dev/null || return 0
  printf '{"provider":"%s"}\n' "$1" >"$XMLUI_DESKTOP_AGENT_HINT"
}

_xmlui_has_repo_setup() {
  [ -f "resources/.worklist-authorization.json" ] || [ -f ".claude/xmlui-desktop-conventions.md" ]
}

_xmlui_codex_seed_text() {
  local seed_path
  seed_path="$_XMLUI_SHELL_DIR/codex-startup-instructions.md"
  [ -f "$seed_path" ] || return 1
  cat "$seed_path"
}

_xmlui_codex_is_subcommand() {
  case "$1" in
    exec|review|login|logout|mcp|plugin|mcp-server|app-server|remote-control|app|completion|update|sandbox|debug|apply|resume|fork|cloud|exec-server|features|help)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

claude() {
  _xmlui_mark_agent "claude"
  command claude "$@"
}

# Verify the user-global codex worklist guard is wired (script present +
# marker block in ~/.codex/config.toml). Used to refuse launching codex in a
# managed repo without enforcement — otherwise the convention is silently
# unprotected and the user thinks they have a gate when they don't.
_xmlui_codex_hook_installed() {
  local script="$HOME/.xmlui-desktop/codex-worklist-guard.py"
  local config="$HOME/.codex/config.toml"
  [ -x "$script" ] || return 1
  [ -f "$config" ] || return 1
  grep -q '^# xmlui-desktop:start' "$config" || return 1
  return 0
}

codex() {
  _xmlui_mark_agent "codex"
  if ! _xmlui_has_repo_setup; then
    command codex "$@"
    return
  fi
  if ! _xmlui_codex_hook_installed; then
    printf '%s\n' \
      "Codex requires the xmlui-desktop worklist guard, but it is not installed." \
      "" \
      "Expected:" \
      "  - script:  ~/.xmlui-desktop/codex-worklist-guard.py (executable)" \
      "  - config:  ~/.codex/config.toml containing the xmlui-desktop:start marker" \
      "" \
      "Run Setup in xmlui-desktop to install the guard, then retry." >&2
    return 1
  fi
  local seed_text
  seed_text="$(_xmlui_codex_seed_text)" || {
    command codex "$@"
    return
  }
  if [ $# -eq 0 ]; then
    command codex "$seed_text"
    return
  fi
  local args=()
  local prompt=""
  local expect_value=0
  while [ $# -gt 0 ]; do
    local arg="$1"
    shift
    if [ "$expect_value" -eq 1 ]; then
      args+=("$arg")
      expect_value=0
      continue
    fi
    case "$arg" in
      -c|--config|--enable|--disable|-i|--image|-m|--model|-p|--profile|-s|--sandbox|-C|--cd|--add-dir|-a|--ask-for-approval|--remote|--remote-auth-token-env|--local-provider|--output-schema|-o|--output-last-message)
        args+=("$arg")
        expect_value=1
        continue
        ;;
      --*=*)
        args+=("$arg")
        continue
        ;;
      -*)
        args+=("$arg")
        continue
        ;;
      *)
        if _xmlui_codex_is_subcommand "$arg"; then
          command codex "${args[@]}" "$arg" "$@"
          return
        fi
        prompt="$arg"
        break
        ;;
    esac
  done
  if [ -n "$prompt" ]; then
    command codex "${args[@]}" "$seed_text"$'\n\n'"Additional user request: $prompt"
  else
    command codex "${args[@]}" "$seed_text"
  fi
}
