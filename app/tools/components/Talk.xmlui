<Component name="Talk" var.turns="{sessionTurns(latestSession.value)}" var.fullscreenImage="{null}">
  <DataSource
    id="latestSession"
    url="/__sessions/latest"
    pollIntervalInSeconds="2" />

  <ChangeListener
    listenTo="{turns.length}"
    onDidChange="if (window.wasPinnedToBottom()) window.scrollAllToBottom()" />

  <ChangeListener
    listenTo="{turns.filter(t => t.role === 'user' && !t.text.startsWith('[Request interrupted')).length}"
    onDidChange="escSuppressed = false" />

  <ModalDialog
    when="{!!fullscreenImage}"
    fullScreen="true"
    onClose="fullscreenImage = null">
    <Image
      src="{(fullscreenImage || '').startsWith('data:') || (fullscreenImage || '').startsWith('http') ? fullscreenImage : '/__file?path=' + encodeURIComponent(fullscreenImage || '')}"
      fit="contain"
      width="100%"
      height="100%" />
  </ModalDialog>

  <VStack padding="$space-6" gap="$space-3">
    <StickyBox to="top">
      <HStack gap="$space-3" verticalAlignment="center" paddingVertical="$space-2">
        <Heading level="h2">Transcript</Heading>
        <SpaceFiller />
        <Button
          icon="down"
          variant="ghost"
          size="xs"
          tooltip="Scroll to bottom"
          onClick="window.scrollAllToBottom()" />
      </HStack>
    </StickyBox>

    <Text
      when="{!turns || turns.length === 0}"
      color="$textColor-secondary">
      (no messages yet)
    </Text>

    <Items data="{turns}">
      <VStack
        gap="$space-1"
        padding="$space-3"
        borderRadius="$borderRadius"
        backgroundColor="{$item.role === 'user' ? '$color-info-50' : '$color-surface-50'}">
        <Text
          fontSize="$fontSize-sm"
          fontWeight="$fontWeight-bold"
          color="{$item.role === 'user' ? '$color-info-700' : '$color-success-700'}"
          value="{$item.role === 'user' ? 'You' : 'Claude'}" />
        <Markdown
          content="{$item.role === 'user' ? formatUserTurnForTranscript($item.text) : $item.text}" />
        <VStack gap="$space-2" when="{$item.images && $item.images.length > 0}">
          <Items data="{$item.images}">
            <Link onClick="fullscreenImage = $item" noIndicator>
              <Image
                src="{$item.startsWith('data:') || $item.startsWith('http') ? $item : '/__file?path=' + encodeURIComponent($item)}"
                maxHeight="200px"
                fit="contain" />
            </Link>
          </Items>
        </VStack>
      </VStack>
    </Items>

    <HStack
      when="{isWaitingForAssistant(latestSession.value) && !escSuppressed}"
      paddingVertical="$space-3"
      verticalAlignment="center">
      <Spinner size="sm" delay="{200}" />
    </HStack>

    <StickyBox to="bottom">
      <HStack horizontalAlignment="end" paddingVertical="$space-2">
        <Button
          icon="up"
          variant="ghost"
          size="xs"
          tooltip="Scroll to top"
          onClick="window.scrollAllToTop()" />
      </HStack>
    </StickyBox>
  </VStack>
</Component>
