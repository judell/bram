<Component
  name="Workspace"
  var.checked="{loadChecked()}"
  var.submitting="{!!getInflight()}"
  var.expandedItemId="{null}"
  var.activeSnapshot="{null}"
  var.lastJsonl="{null}"
  var.sessionTick="{0}"
  var.statusHelpFor="{null}">
  <DataSource
    id="sessionTail"
    url="/__sessions/latest-tail?lines=200&amp;t={sessionTick}"
    dataType="text" />
  <ChangeListener
    listenTo="{sessionTail.value}"
    onDidChange="(c) => {
      if (c.newValue) lastJsonl = c.newValue;
      // Reactive turn-done check: every time the session JSONL changes,
      // clear the dim once the agent's turn has actually ended. The signal
      // is isAgentIdle (looks for end_turn on Claude or task_complete on
      // codex) rather than isWaitingForAssistant (which flips false the
      // moment the assistant emits any text and would undim mid-turn
      // during narration). Keep only a short grace so the freshly-sent
      // user turn has time to land in the JSONL, then refetch the
      // worklist/history immediately when the agent goes idle instead
      // of waiting on the slower follow-on polls. The stale-timeout
      // check in worklist onLoaded below is the long-tail safety net
      // for sessions that never idle.
      const stored = getInflight();
      if (!stored) return;
      const elapsed = Date.now() - (stored.ts || 0);
      if (elapsed < 750) return;
      if (!isAgentIdle(c.newValue)) return;
      clearInflight();
      submitting = false;
      saveChecked([]);
      checked = [];
      worklist.refetch();
      history.refetch();
    }" />
  <DataSource
    id="worklist"
    url="/__worklist"
    onLoaded="(data) => {
      const items = (data && data.items) || [];
      const stored = getInflight();
      if (stored) {
        const sig = items
          .filter(i => i && i.id)
          .map(i => i.id + ':' + (i.status || 'proposed'))
          .sort()
          .join(',');
        if (sig !== (stored.ids || '')) {
          clearInflight();
          submitting = false;
          saveChecked([]);
          checked = [];
          checked = pruneChecked(items.map(i => i.id));
          return;
        }
        // 180s stale-timeout safety net for cases where the agent never
        // emits a textful response (e.g., it crashes or the user kills
        // the session). The session-activity clear lives in the
        // ChangeListener above; this branch is only here to recover from
        // a stuck inflight flag.
        if (Date.now() - (stored.ts || 0) > 180000) {
          clearInflight();
          submitting = false;
          saveChecked([]);
          checked = [];
          return;
        }
      }
      checked = pruneChecked(items.map(i => i.id));
    }" />
  <DataSource
    id="history"
    url="/__worklist-history/list" />

  <VStack
    padding="$space-6"
    gap="$space-6"
    onInit="onTalkSessionChange(() => {
      if (!submitting) return;
      debounce(400, () => {
        if (submitting) sessionTick = sessionTick + 1;
      });
    });
    (() => { const tauri = (window.parent &amp;&amp; window.parent.__TAURI__) || window.__TAURI__; if (tauri &amp;&amp; tauri.event &amp;&amp; tauri.event.listen) { tauri.event.listen('worklist-changed', () => { worklist.refetch(); history.refetch(); }); } })()">
    <VStack gap="$space-3" when="{worklist.value}">
      <VStack gap="$space-3">
        <Heading level="h2">Worklist</Heading>
        <Text
          when="{worklist.value.exists && (!worklist.value.items || worklist.value.items.length === 0)}"
          color="$textColor-secondary">
          (none)
        </Text>
        <Text
          when="{worklist.value.items && worklist.value.items.length > 0}"
          value="{worklist.value.description}" />
        <Items data="{worklist.value.items}">
          <VStack gap="$space-1">
            <HStack gap="$space-3" verticalAlignment="start">
              <Checkbox
                value="{checked.includes($item.id)}"
                enabled="{!submitting}"
                onDidChange="(v) => { checked = v ? [...checked, $item.id] : checked.filter(id => id !== $item.id); saveChecked(checked); }" />
              <VStack gap="$space-1" width="*">
                <HStack gap="$space-2" verticalAlignment="center">
                  <Text
                    value="{($item.status || 'proposed') === 'applied' ? 'TO COMMIT' : 'TO APPLY'}"
                    fontSize="$fontSize-xs"
                    fontWeight="$fontWeight-bold"
                    color="{($item.status || 'proposed') === 'applied' ? '$color-success-600' : '$color-info-600'}" />
                  <Button
                    when="{$itemIndex === worklist.value.items.findIndex(i => (i.status || 'proposed') === ($item.status || 'proposed'))}"
                    label="ⓘ"
                    variant="ghost"
                    size="xs"
                    tooltip="What does this badge mean?"
                    onClick="statusHelpFor = ($item.status || 'proposed')" />
                  <Text value="{$item.id}" fontWeight="$fontWeight-bold" />
                  <Link
                    onClick="expandedItemId = (expandedItemId === $item.id ? null : $item.id)"
                    noIndicator>
                    <Text
                      value="{expandedItemId === $item.id ? 'hide details' : 'show details'}"
                      fontSize="$fontSize-xs" />
                  </Link>
                </HStack>
                <Text value="{$item.file}" variant="code" />
                <VStack
                  when="{expandedItemId === $item.id}"
                  gap="$space-2"
                  paddingTop="$space-2">
                  <VStack gap="$space-1" when="{$item.before}">
                    <Text fontWeight="$fontWeight-bold" fontSize="$fontSize-sm" value="Before" />
                    <Markdown content="{$item.before}" />
                  </VStack>
                  <VStack gap="$space-1" when="{$item.after}">
                    <Text fontWeight="$fontWeight-bold" fontSize="$fontSize-sm" value="After" />
                    <Markdown content="{$item.after}" />
                  </VStack>
                </VStack>
              </VStack>
            </HStack>
            <VStack
              when="{expandedItemId === $item.id && $item.diff}"
              gap="0"
              marginLeft="$space-8"
              padding="$space-2"
              backgroundColor="$color-surface-50"
              borderRadius="$borderRadius"
              overflowX="auto">
              <Items data="{$item.diff.split('\n')}">
                <Text
                  fontFamily="$fontFamily-monospace"
                  fontSize="$fontSize-sm"
                  paddingHorizontal="$space-2"
                  whiteSpace="pre"
                  backgroundColor="{
                    $item.startsWith('@@') ? '#e0f2fe' :
                    ($item.startsWith('+') && !$item.startsWith('+++')) ? '#dcfce7' :
                    ($item.startsWith('-') && !$item.startsWith('---')) ? '#fee2e2' :
                    'transparent'
                  }"
                  value="{$item || ' '}" />
              </Items>
            </VStack>
          </VStack>
        </Items>
        <VStack
          gap="$space-3"
          when="{worklist.value.items && worklist.value.items.length > 0}">
          <HStack gap="$space-3" verticalAlignment="center">
            <Button
              label="Approve selected ({checked.length})"
              enabled="{!submitting && checked.length > 0}"
              onClick="markInflight(worklist.value && worklist.value.items); submitting = true; toTurn('approved: ' + JSON.stringify({ items: worklist.value.items.filter(i => checked.includes(i.id)).map(i => ({id: i.id, hash: i.hash})), feedback: '' }))" />
            <Button
              label="Drop selected ({checked.length})"
              variant="outlined"
              enabled="{!submitting && checked.length > 0}"
              onClick="markInflight(worklist.value && worklist.value.items); submitting = true; toTurn('drop: ' + JSON.stringify({ items: worklist.value.items.filter(i => checked.includes(i.id)).map(i => ({id: i.id, hash: i.hash})), feedback: '' }))" />
            <Spinner when="{submitting}" size="sm" />
            <Button
              when="{submitting}"
              label="Cancel pending"
              variant="outlined"
              onClick="clearInflight(); submitting = false" />
          </HStack>
        </VStack>
      </VStack>
    </VStack>

    <ModalDialog
      when="{statusHelpFor === 'proposed'}"
      title="TO APPLY"
      onClose="statusHelpFor = null">
      <VStack gap="$space-3" padding="$space-2">
        <Text>
          The agent is asking permission to make file edits. Nothing has happened
          on disk yet. In this phase you can:
        </Text>
        <Markdown content="- **Check** the items you want to authorize, **uncheck** the rest.
- Click **Approve selected** to authorize the checked items — the agent applies the edits and the items transition to TO COMMIT.
- Click **Drop selected** to discard items you don't want at all — they're removed without any file changes.
- Ask the agent in chat to tweak an item's scope, before/after prose, or split it up — useful when the proposal is *almost* right." />
        <HStack>
          <Button label="Got it" onClick="statusHelpFor = null" />
        </HStack>
      </VStack>
    </ModalDialog>

    <ModalDialog
      when="{statusHelpFor === 'applied'}"
      title="TO COMMIT"
      onClose="statusHelpFor = null">
      <VStack gap="$space-3" padding="$space-2">
        <Text>
          The agent has made the file edits and the change is sitting in your
          working tree, not yet committed. This phase is intentionally
          fluid — you don't have to approve or drop right away. You can:
        </Text>
        <Markdown content="- **Verify** the change actually does what was promised — reload the right pane, run the affected feature, read the diff.
- **Ask for follow-on tweaks** that get folded into the *same* item (the agent expands the item's `after` and applies more edits, the commit you eventually approve covers the whole thing). This is preferred over proposing a sibling item.
- Click **Approve selected** when you're satisfied — the agent creates the git commit with the item's prose as the message.
- Click **Drop selected** if it turned out wrong — the worklist entry is removed, but **the disk edits stay** (the agent doesn't revert files unilaterally). Ask the agent to *discard those changes if you want them gone* — it knows how to use git commands like `git checkout -- &lt;file&gt;` or `git restore &lt;file&gt;`." />
        <HStack>
          <Button label="Got it" onClick="statusHelpFor = null" />
        </HStack>
      </VStack>
    </ModalDialog>

    <VStack gap="$space-3" when="{history.value && history.value.length > 0}">
      <Heading level="h2">History</Heading>
      <ModalDialog id="historySnapshotDialog" title="{activeSnapshot &amp;&amp; activeSnapshot.iso}">
        <Markdown content="{activeSnapshot &amp;&amp; activeSnapshot.changelog}" />
      </ModalDialog>
      <Table data="{history.value}">
        <Column header="details" width="80px">
          <Link
            onClick="activeSnapshot = $item; historySnapshotDialog.open()"
            noIndicator>
            <Text value="show" fontSize="$fontSize-xs" />
          </Link>
        </Column>
        <Column bindTo="summary" header="action" width="140px" />
        <Column header="items">
          <Text
            value="{$item.ids &amp;&amp; $item.ids.join(', ')}"
            overflowMode="flow"
            breakMode="word" />
        </Column>
        <Column header="when" width="160px">
          <Text value="{$item.iso &amp;&amp; $item.iso.slice(0, 16)}" fontSize="$fontSize-sm" />
        </Column>
      </Table>
    </VStack>
  </VStack>
</Component>
