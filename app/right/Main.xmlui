<App>
  <DataSource id="manualSrc" url="manual.md" />

  <AppHeader title="XMLUI">
    <Text fontSize="$fontSize-sm">
      Claude or Codex can use this app for interaction and display
    </Text>
    <property name="profileMenuTemplate">
      <HStack width="100%" gap="$space-2" verticalAlignment="center" horizontalAlignment="end">
        <Button
          icon="up"
          variant="ghost"
          tooltip="Scroll to top"
          onClick="window.scrollAllToTop()" />
        <Button
          icon="down"
          variant="ghost"
          tooltip="Scroll to bottom"
          onClick="window.scrollAllToBottom()" />
        <Button
          icon="wrench"
          variant="ghost"
          tooltip="Open developer tools"
          onClick="window.parent.postMessage({ type: 'right-pane', kind: 'open-devtools' }, '*')" />
        <Button
          icon="code"
          variant="ghost"
          tooltip="View source of Main.xmlui"
          onClick="mainSrc.open()" />
        <Button
          icon="help"
          variant="ghost"
          tooltip="Open the user manual"
          onClick="manualDialog.open()" />
        <Inspector src="{'../vendor/xs-diff.html?v=' + window.APP_VERSION}" />
      </HStack>
    </property>
  </AppHeader>

  <Footer>
    <HStack width="100%" gap="$space-2" verticalAlignment="center" horizontalAlignment="end">
      <Button
        icon="up"
        variant="ghost"
        tooltip="Scroll to top"
        onClick="window.scrollAllToTop()" />
      <Button
        icon="down"
        variant="ghost"
        tooltip="Scroll to bottom"
        onClick="window.scrollAllToBottom()" />
      <Button
        icon="wrench"
        variant="ghost"
        tooltip="Open developer tools"
        onClick="window.parent.postMessage({ type: 'right-pane', kind: 'open-devtools' }, '*')" />
      <Button
        icon="code"
        variant="ghost"
        tooltip="View source of Main.xmlui"
        onClick="mainSrc.open()" />
      <Button
        icon="help"
        variant="ghost"
        tooltip="Open the user manual"
        onClick="manualDialog.open()" />
      <Inspector src="{'../vendor/xs-diff.html?v=' + window.APP_VERSION}" />
    </HStack>
  </Footer>

  <Theme maxWidth-ModalDialog="820px">
    <ModalDialog id="manualDialog" title="User manual">
      <Theme
        marginTop-H1-markdown="0"
        marginBottom-H1-markdown="$space-2"
        marginTop-H2-markdown="$space-3"
        marginBottom-H2-markdown="$space-1"
        marginTop-H3-markdown="$space-2"
        marginBottom-H3-markdown="$space-1"
        marginBottom-Text-markdown="$space-1"
        marginBottom-Ul-markdown="$space-2"
        marginBottom-Ol-markdown="$space-2"
        marginBottom-Li-markdown="$space-1">
        <Markdown content="{manualSrc.value}" showHeadingAnchors="{true}" />
      </Theme>
    </ModalDialog>
  </Theme>

  <ViewSource id="mainSrc" file="Main.xmlui" />
  <Architecture />

</App>
