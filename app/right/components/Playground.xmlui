<Component name="Playground" var.selectedSha="{null}" var.unchecked="{[]}">
  <DataSource id="proposal" url="resources/proposal.json" />

  <DataSource
    id="commits"
    url="https://api.github.com/repos/judell/xmlui-claude-code-desktop/commits"
    queryParams="{{ per_page: 12 }}" />

  <DataSource
    id="commitDetail"
    url="https://api.github.com/repos/judell/xmlui-claude-code-desktop/commits/{selectedSha}"
    when="{!!selectedSha}" />

  <VStack padding="$space-6" gap="$space-6">
    <VStack gap="$space-3" when="{proposal.value}">
      <Heading level="h2" value="{proposal.value.title}" />
      <Text value="{proposal.value.description}" />
      <Items data="{proposal.value.items}">
        <HStack gap="$space-3" verticalAlignment="center">
          <Checkbox
            initialValue="true"
            onDidChange="(v) => { unchecked = v ? unchecked.filter(id => id !== $item.id) : [...unchecked, $item.id] }" />
          <Text width="220px" value="{$item.file}" variant="code" maxLines="1" />
          <Text value="{$item.before}" />
          <Text value="→" />
          <Text value="{$item.after}" />
        </HStack>
      </Items>
      <HStack gap="$space-3" verticalAlignment="center">
        <Button
          label="Approve selected ({proposal.value.items.length - unchecked.length})"
          onClick="toTurn('approved: ' + JSON.stringify(proposal.value.items.filter(i => !unchecked.includes(i.id))))" />
        <Text fontSize="$fontSize-sm" color="$textColor-secondary">
          Sends the approved subset to the chat as a fresh user message.
        </Text>
      </HStack>
    </VStack>

    <Heading level="h2">Recent commits</Heading>
    <Text fontSize="$fontSize-sm">Click a SHA to view its diff. Click the GitHub icon to open on github.com.</Text>
    <Table data="{commits.value}" width="100%">
      <Column header="SHA" width="120px">
        <HStack gap="$space-2" verticalAlignment="center">
          <Link onClick="selectedSha = $item.sha" noIndicator>
            <Text value="{$item.sha.slice(0, 7)}" variant="code" />
          </Link>
          <Button
            icon="link"
            variant="ghost"
            size="xs"
            tooltip="Open on github.com"
            onClick="openExternal($item.html_url)" />
        </HStack>
      </Column>
      <Column header="Date" width="160px">
        <Text value="{formatDateTime($item.commit.author.date, 'yyyy-MM-dd HH:mm')}" />
      </Column>
      <Column header="Subject" width="*">
        <Text value="{$item.commit.message.split('\n')[0]}" maxLines="1" />
      </Column>
      <Column header="Author" width="120px">
        <Text value="{$item.commit.author.name}" />
      </Column>
    </Table>

    <VStack gap="$space-3" when="{!!selectedSha}">
      <HStack gap="$space-3" verticalAlignment="center">
        <Heading level="h3" value="Diff: {selectedSha.slice(0, 7)}" />
        <Button
          icon="close"
          variant="ghost"
          size="xs"
          tooltip="Clear selection"
          onClick="selectedSha = null" />
      </HStack>
      <Text when="{commitDetail.inProgress}">Loading…</Text>
      <VStack gap="$space-4" when="{commitDetail.value}">
        <Text fontSize="$fontSize-sm">
          {commitDetail.value.commit.message.split('\n')[0]}
          {' — '}
          +{commitDetail.value.stats.additions} / -{commitDetail.value.stats.deletions}
          {' across '}
          {commitDetail.value.files.length} file(s)
        </Text>
        <Items data="{commitDetail.value.files}">
          <VStack gap="0" borderTop="1px solid $borderColor" paddingTop="$space-2">
            <HStack gap="$space-3" verticalAlignment="center" paddingBottom="$space-2">
              <Text fontWeight="$fontWeight-bold" value="{$item.filename}" />
              <Text color="green" value="+{$item.additions}" />
              <Text color="red" value="-{$item.deletions}" />
            </HStack>
            <VStack gap="0" overflowX="auto">
              <Items data="{$item.patch ? $item.patch.split('\n') : ['(no textual diff)']}">
                <Text
                  fontFamily="$fontFamily-monospace"
                  fontSize="$fontSize-sm"
                  paddingHorizontal="$space-2"
                  whiteSpace="pre"
                  backgroundColor="{
                    $item.startsWith('@@') ? '#e0f2fe' :
                    ($item.startsWith('+') && !$item.startsWith('+++')) ? '#dcfce7' :
                    ($item.startsWith('-') && !$item.startsWith('---')) ? '#fee2e2' :
                    'transparent'
                  }"
                  value="{$item || ' '}" />
              </Items>
            </VStack>
          </VStack>
        </Items>
      </VStack>
    </VStack>
  </VStack>
</Component>
