<Component name="Talk"
  var.lastJsonl="{null}"
  var.turns="{sessionTurns(lastJsonl)}"
  var.fullscreenImage="{null}"
  var.openToolId="{null}"
  var.turnLimit="{50}"
  var.sessionTick="{0}"
  var.showAll="{false}">
  <DataSource
    id="sessionMeta"
    url="/__sessions/latest-meta"
    pollIntervalInSeconds="0.5" />
  <DataSource
    id="pendingPoll"
    url="/__sessions/latest-pending"
    pollIntervalInSeconds="2"
    structuralSharing="false" />
  <ChangeListener
    listenTo="{sessionMeta.value &amp;&amp; sessionMeta.value.size}"
    onDidChange="sessionTick = sessionTick + 1" />
  <DataSource
    id="latestSession"
    url="/__sessions/latest-tail?lines={showAll ? 'all' : '200'}&amp;t={sessionTick}"
    dataType="text"
  />

  <ChangeListener
    listenTo="{turns.length}"
    onDidChange="if (window.wasPinnedToBottom()) window.scrollAllToBottom()" />

  <ChangeListener
    listenTo="{pendingUserText}"
    onDidChange="if (pendingUserText &amp;&amp; window.wasPinnedToBottom()) window.scrollAllToBottom()" />

  <ChangeListener
    listenTo="{pendingPoll.value &amp;&amp; pendingPoll.value.pending &amp;&amp; pendingPoll.value.pending.id}"
    onDidChange="(c) => { try { logToHost({ kind: 'pendingPoll-transition', oldId: c.prevValue || null, newId: c.newValue || null, name: (pendingPoll.value &amp;&amp; pendingPoll.value.pending &amp;&amp; pendingPoll.value.pending.name) || null }) } catch (e) {}; if (window.wasPinnedToBottom()) window.scrollAllToBottom() }" />

  <ChangeListener
    listenTo="{(isWaitingForAssistant(lastJsonl) || pendingUserText) &amp;&amp; !escSuppressed &amp;&amp; !(pendingPoll.value &amp;&amp; pendingPoll.value.pending)}"
    onDidChange="(c) => { try { logToHost({ kind: 'spinner-state', visible: !!c.newValue, isWaiting: isWaitingForAssistant(lastJsonl), pendingUserText: !!pendingUserText, escSuppressed: escSuppressed, hasPending: !!(pendingPoll.value &amp;&amp; pendingPoll.value.pending) }) } catch (e) {} }" />

  <ChangeListener
    listenTo="{turns.filter(t => t.role === 'user' && !t.text.startsWith('[Request interrupted')).length}"
    onDidChange="escSuppressed = false" />

  <ChangeListener
    listenTo="{latestSession.value}"
    onDidChange="(c) => { if (c.newValue) lastJsonl = c.newValue }" />

  <ChangeListener
    listenTo="{lastJsonl}"
    onDidChange="(c) => { if (pendingUserText &amp;&amp; pendingMatchesTurn(sessionTurns(c.newValue || lastJsonl), pendingUserText)) pendingUserText = '' }" />


  <ModalDialog
    when="{!!fullscreenImage}"
    fullScreen="true"
    onClose="fullscreenImage = null">
    <Image
      src="{(fullscreenImage || '').startsWith('data:') || (fullscreenImage || '').startsWith('http') ? fullscreenImage : '/__file?path=' + encodeURIComponent(fullscreenImage || '')}"
      fit="contain"
      width="100%"
      height="100%" />
  </ModalDialog>

  <ModalDialog
    when="{!!openToolId}"
    onClose="openToolId = null"
    title="{(findToolInTurns(turns, openToolId) || {}).name || 'Tool'}"
    var.openTool="{findToolInTurns(turns, openToolId)}"
    var.openDetail="{getToolDetail(lastJsonl, openToolId)}"
    var.modalInput="{openDetail &amp;&amp; openDetail.input}"
    var.modalResult="{openDetail &amp;&amp; openDetail.result}">
    <VStack gap="$space-2">
      <Text
        when="{openTool &amp;&amp; openTool.summary}"
        fontFamily="$fontFamily-monospace"
        fontSize="$fontSize-sm"
        color="$textColor-secondary"
        value="{openTool.summary}" />
      <Items
        when="{openTool &amp;&amp; (openTool.name === 'Edit' || openTool.name === 'MultiEdit')}"
        data="{editDiffLines(modalInput)}">
        <Text
          fontFamily="$fontFamily-monospace"
          fontSize="$fontSize-sm"
          whiteSpace="pre-wrap"
          paddingHorizontal="$space-2"
          backgroundColor="{$item.kind === 'del' ? '$color-danger-100' : '$color-success-100'}"
          value="{$item.sign + ' ' + $item.text}" />
      </Items>
      <VStack when="{openTool &amp;&amp; openTool.name === 'Write'}" gap="{0}" var.writeBody="{writeBodyLines(modalInput, 200)}">
        <Items data="{writeBody.lines}">
          <Text
            fontFamily="$fontFamily-monospace"
            fontSize="$fontSize-sm"
            whiteSpace="pre-wrap"
            paddingHorizontal="$space-2"
            value="{$item}" />
        </Items>
        <Text
          when="{writeBody.remaining > 0}"
          fontSize="$fontSize-xs"
          color="$textColor-secondary"
          paddingHorizontal="$space-2"
          value="{writeBody.remaining + ' more line' + (writeBody.remaining === 1 ? '' : 's') + '…'}" />
      </VStack>
      <VStack when="{openTool &amp;&amp; openTool.name === 'Bash'}" gap="$space-1">
        <Text
          fontFamily="$fontFamily-monospace"
          fontSize="$fontSize-sm"
          whiteSpace="pre-wrap"
          paddingHorizontal="$space-2"
          value="{modalInput.command}" />
        <Text
          when="{modalInput.description}"
          fontSize="$fontSize-xs"
          color="$textColor-secondary"
          paddingHorizontal="$space-2"
          value="{modalInput.description}" />
      </VStack>
      <VStack
        when="{openTool &amp;&amp; openTool.name !== 'Edit' &amp;&amp; openTool.name !== 'MultiEdit' &amp;&amp; openTool.name !== 'Write' &amp;&amp; openTool.name !== 'Bash'}"
        gap="{0}"
        var.genericBody="{toolInputJsonLines(modalInput, 200)}">
        <Items data="{genericBody.lines}">
          <Text
            fontFamily="$fontFamily-monospace"
            fontSize="$fontSize-sm"
            whiteSpace="pre-wrap"
            paddingHorizontal="$space-2"
            value="{$item}" />
        </Items>
        <Text
          when="{genericBody.remaining > 0}"
          fontSize="$fontSize-xs"
          color="$textColor-secondary"
          paddingHorizontal="$space-2"
          value="{genericBody.remaining + ' more line' + (genericBody.remaining === 1 ? '' : 's') + '…'}" />
      </VStack>
      <VStack when="{modalResult &amp;&amp; modalResult.lines.length > 0}" gap="{0}" marginTop="$space-2">
        <Text
          fontSize="$fontSize-xs"
          fontWeight="$fontWeight-bold"
          color="$textColor-secondary"
          paddingHorizontal="$space-2"
          value="Result" />
        <Items data="{modalResult.lines}">
          <Text
            fontFamily="$fontFamily-monospace"
            fontSize="$fontSize-sm"
            whiteSpace="pre-wrap"
            paddingHorizontal="$space-2"
            color="{openTool &amp;&amp; openTool.errored ? '$color-danger-700' : ''}"
            value="{$item}" />
        </Items>
        <Text
          when="{modalResult.remaining > 0}"
          fontSize="$fontSize-xs"
          color="$textColor-secondary"
          paddingHorizontal="$space-2"
          value="{modalResult.remaining + ' more line' + (modalResult.remaining === 1 ? '' : 's') + '…'}" />
      </VStack>
    </VStack>
  </ModalDialog>

  <VStack padding="$space-6" gap="$space-3"
    onInit="onTalkSessionChange(() => sessionTick = sessionTick + 1); try { logToHost({ kind: 'talk-mount', at: new Date().toISOString() }) } catch (e) {}">
    <StickyBox to="top">
      <HStack gap="$space-3" verticalAlignment="center" paddingVertical="$space-2">
        <Heading level="h2">Transcript</Heading>
        <SpaceFiller />
        <Button
          icon="down"
          variant="ghost"
          size="xs"
          tooltip="Scroll to bottom"
          onClick="window.scrollAllToBottom()" />
      </HStack>
    </StickyBox>

    <Link
      when="{!showAll || turns.length > turnLimit}"
      onClick="if (!showAll) { showAll = true; sessionTick = sessionTick + 1; } else { turnLimit = turns.length; }"
      noIndicator="true">
      <Text fontSize="$fontSize-sm" color="$textColor-secondary"
        value="{showAll ? ('Show all (' + (turns.length - turnLimit) + ' earlier)') : 'Show earlier turns'}" />
    </Link>

    <Items data="{visibleTurns(turns, turnLimit)}">
      <VStack
        gap="$space-1"
        padding="$space-3"
        borderRadius="$borderRadius"
        backgroundColor="{$item.role === 'user' ? '$color-info-50' : '$color-surface-50'}"
        var.turnRole="{$item.role}"
        var.turnImages="{$item.images}">
        <Text
          fontSize="$fontSize-sm"
          fontWeight="$fontWeight-bold"
          color="{turnRole === 'user' ? '$color-info-700' : '$color-success-700'}"
          value="{turnRole === 'user' ? 'You' : 'Claude'}" />
        <Items data="{$item.entries}">
          <Markdown
            when="{$item.kind === 'text'}"
            content="{turnRole === 'user' ? formatUserTurnForTranscript($item.text) : $item.text}" />
          <VStack
            when="{$item.kind === 'tool'}"
            gap="$space-1"
            padding="$space-2"
            borderRadius="$borderRadius"
            border="1px solid $borderColor"
            backgroundColor="$color-surface-100"
            var.toolId="{$item.id}"
            var.toolName="{$item.name}"
            var.toolErrored="{$item.errored}"
            var.toolErrorText="{$item.errorText}"
            var.toolSummaryText="{$item.summary}">
            <Link onClick="openToolId = toolId" noIndicator="true">
              <HStack gap="$space-2" verticalAlignment="center">
                <Text
                  fontFamily="$fontFamily-monospace"
                  fontSize="$fontSize-xs"
                  fontWeight="$fontWeight-bold"
                  paddingHorizontal="$space-1_5"
                  paddingVertical="$space-0_5"
                  borderRadius="$borderRadius"
                  backgroundColor="$color-surface-200"
                  value="{toolName}" />
                <Text fontSize="$fontSize-sm" value="{toolSummaryText}" />
                <SpaceFiller />
                <Text fontFamily="$fontFamily-monospace" fontSize="$fontSize-xs" color="$textColor-secondary" value="↗" />
              </HStack>
            </Link>
            <Text
              when="{toolErrored &amp;&amp; toolErrorText}"
              color="$color-danger-700"
              fontSize="$fontSize-sm"
              value="{toolErrorText}" />
          </VStack>
        </Items>
        <VStack gap="$space-2" when="{turnImages &amp;&amp; turnImages.length > 0}">
          <Items data="{turnImages}">
            <Link onClick="fullscreenImage = $item" noIndicator>
              <Image
                src="{$item.startsWith('data:') || $item.startsWith('http') ? $item : '/__file?path=' + encodeURIComponent($item)}"
                maxHeight="200px"
                fit="contain" />
            </Link>
          </Items>
        </VStack>
      </VStack>
    </Items>

    <VStack
      when="{pendingUserText &amp;&amp; !pendingMatchesTurn(turns, pendingUserText)}"
      gap="$space-1"
      padding="$space-3"
      borderRadius="$borderRadius"
      backgroundColor="$color-info-50">
      <Text fontSize="$fontSize-sm" fontWeight="$fontWeight-bold" color="$color-info-700" value="You" />
      <Markdown content="{formatUserTurnForTranscript(pendingUserText)}" />
    </VStack>

    <VStack
      when="{pendingPoll.value &amp;&amp; pendingPoll.value.pending}"
      gap="$space-2"
      padding="$space-3"
      borderRadius="$borderRadius"
      border="1px solid $color-warn-200"
      backgroundColor="$color-warn-50"
      var.pendingTool="{pendingPoll.value.pending}"
      var.pendingSummary="{toolSummary(pendingTool.name, pendingTool.input || {})}">
      <Text fontSize="$fontSize-sm" color="$color-warn-800">
        Claude wants to use <Text fontFamily="$fontFamily-monospace" inline="true">{pendingTool.name}</Text>{pendingSummary ? ' — ' : ''}<Text fontFamily="$fontFamily-monospace" inline="true">{pendingSummary}</Text>
      </Text>
      <HStack gap="$space-2" wrapContent="true">
        <Button label="1. Yes" variant="outlined" size="sm" onClick="sendKeys('1\r')" />
        <Button label="2. Yes, allow and don't ask again" variant="outlined" size="sm" onClick="sendKeys('2\r')" />
        <Button label="3. No, and tell Claude what to do" variant="outlined" size="sm" onClick="sendKeys('3\r')" />
      </HStack>
    </VStack>

    <HStack
      when="{(isWaitingForAssistant(lastJsonl) || pendingUserText) &amp;&amp; !escSuppressed &amp;&amp; !(pendingPoll.value &amp;&amp; pendingPoll.value.pending)}"
      paddingVertical="$space-3"
      verticalAlignment="center">
      <Spinner size="sm" delay="{200}" />
    </HStack>

    <StickyBox to="bottom">
      <HStack
        gap="$space-2"
        padding="$space-2"
        backgroundColor="$color-surface-50"
        borderTop="1px solid $borderColor"
        verticalAlignment="end">
        <Button
          icon="up"
          variant="ghost"
          size="xs"
          tooltip="Scroll to top"
          onClick="window.scrollAllToTop()" />
        <Form
          width="*"
          onSubmit="if (inputBox.value &amp;&amp; inputBox.value.trim()) { pendingUserText = inputBox.value; toTurn(inputBox.value); inputBox.setValue(''); window.scrollAllToBottom() }">
          <property name="buttonRowTemplate">
            <Fragment/>
          </property>
          <HStack gap="$space-2" verticalAlignment="end">
            <TextArea
              id="inputBox"
              enterSubmits="true"
              enabled="{!isWaitingForAssistant(lastJsonl)}"
              placeholder="Message Claude — Enter sends, Shift+Enter newline"
              autoSize="true"
              minRows="1"
              maxRows="6"
              width="*" />
            <Button label="Send" type="submit" size="sm" />
          </HStack>
        </Form>
      </HStack>
    </StickyBox>
  </VStack>
</Component>
